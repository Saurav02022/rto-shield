# Frontend environment variables. Copy to .env.local and fill in.

# URL the Next.js server uses to reach the FastAPI backend.
# Laptop dev only — production comes from GitHub Variables `BACKEND_API_URL`
# injected at Cloud Run (`deploy-frontend.yml`).
BACKEND_API_URL=http://localhost:8000

# Optional public mirror — only needed when a `'use client'` component must
# know the public origin (rarely; current code does not use it).
NEXT_PUBLIC_BACKEND_API_URL=
